echo            both
units           metal
dimension       3
boundary        p p p
atom_style      atomic

variable        procx index *
variable        procy index *
variable        procz index *
include         simulation_plan.lmp

variable        outdir string data
shell           mkdir ${outdir}

processors      ${procx} ${procy} ${procz}

read_restart    gc_rebo2.restart

mass            1 12.011

pair_style      rebo
pair_coeff      * * CH.rebo C

neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes

thermo          1000
thermo_modify   flush yes
timestep        ${thermalize_timestep_ps}

compute         zmin all reduce min z
run             0
variable        shift equal -c_zmin
variable        zlo_shifted equal zlo+v_shift
variable        zhi_shifted equal zhi+v_shift
change_box      all z final ${zlo_shifted} ${zhi_shifted} remap units box

reset_timestep  0
min_style       cg
minimize        1.0e-10 1.0e-10 10000 100000

velocity        all create ${thermalize_temperature_k} ${thermalize_velocity_seed} mom yes rot no dist gaussian
fix             mom all momentum 100 linear 1 1 1

thermo_style    custom step temp pe ke etotal press vol

fix             eq1 all nvt temp ${thermalize_temperature_k} ${thermalize_temperature_k} 0.1
run             ${thermalize_nvt_steps}
unfix           eq1

fix             eq2 all npt temp ${thermalize_temperature_k} ${thermalize_temperature_k} 0.1 iso 0.0 0.0 1.0
run             ${thermalize_npt_steps}
unfix           eq2

fix             eq3 all nve
run             ${thermalize_nve_steps}
unfix           eq3

fix             eq4 all nvt temp ${thermalize_temperature_k} ${thermalize_temperature_k} 0.1
run             ${thermalize_nvt_steps}
unfix           eq4

fix             eq5 all npt temp ${thermalize_temperature_k} ${thermalize_temperature_k} 0.1 iso 0.0 0.0 1.0
run             ${thermalize_npt_steps}
unfix           eq5

fix             eq6 all nve
run             ${thermalize_nve_steps}
unfix           eq6

fix             eq7 all nvt temp ${thermalize_temperature_k} ${thermalize_temperature_k} 0.1
run             ${thermalize_nvt_steps}
unfix           eq7

write_restart   ${outdir}/gc_rebo2_thermalize.restart
write_data      ${outdir}/gc_rebo2_thermalize.data
