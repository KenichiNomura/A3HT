echo            both
units           metal
dimension       3
boundary        p p p
atom_style      atomic

variable        procx index *
variable        procy index *
variable        procz index *
include         simulation_plan.lmp

variable        outdir string data
shell           mkdir ${outdir}

processors      ${procx} ${procy} ${procz}

read_restart    gc_rebo2.restart

mass            1 12.011

pair_style      rebo
pair_coeff      * * CH.rebo C

neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes

thermo          1000
thermo_modify   flush yes
timestep        ${nemd_timestep_ps}

compute         zmin all reduce min z
run             0
variable        shift equal -c_zmin
variable        zlo_shifted equal zlo+v_shift
variable        zhi_shifted equal zhi+v_shift
change_box      all z final ${zlo_shifted} ${zhi_shifted} remap units box

variable        zfreeze_bot_hi equal zlo+v_nemd_freeze_width_a
variable        zfreeze_top_lo equal zhi-v_nemd_freeze_width_a
variable        zcold_lo equal v_zfreeze_bot_hi
variable        zcold_hi equal v_zfreeze_bot_hi+v_nemd_slab_width_a
variable        zhot_lo equal v_zfreeze_top_lo-v_nemd_slab_width_a
variable        zhot_hi equal v_zfreeze_top_lo
variable        zhot_ctr equal 0.5*(v_zhot_lo+v_zhot_hi)
variable        zcold_ctr equal 0.5*(v_zcold_lo+v_zcold_hi)
variable        dz equal abs(v_zhot_ctr-v_zcold_ctr)
variable        area equal lx*ly

region          freeze_bot block INF INF INF INF INF v_zfreeze_bot_hi units box
region          freeze_top block INF INF INF INF v_zfreeze_top_lo INF units box
region          hot block INF INF INF INF v_zhot_lo v_zhot_hi units box
region          cold block INF INF INF INF v_zcold_lo v_zcold_hi units box
group           hot region hot
group           cold region cold
group           freeze_bot region freeze_bot
group           freeze_top region freeze_top
group           frozen union freeze_bot freeze_top
group           mobile subtract all frozen
variable        nhot equal count(hot)
variable        ncold equal count(cold)
print           "NEMD slab atom counts: hot=${nhot} cold=${ncold}"
if              "${nhot} == 0 || ${ncold} == 0" then &
                "print 'ERROR: Hot/cold NEMD slab is empty. Adjust slab/freeze widths or sample geometry.'" &
                "quit 1"

reset_timestep  0
velocity        frozen set 0.0 0.0 0.0
fix             freeze frozen setforce 0.0 0.0 0.0
fix             int mobile nve
fix             mom mobile momentum 100 linear 1 1 1
fix             hotflux all ehex 1000 ${nemd_eflux_ev_ps} region hot
fix             coldflux all ehex 1000 -${nemd_eflux_ev_ps} region cold

compute         Tmobile mobile temp
compute         Thot hot temp/region hot
compute         Tcold cold temp/region cold
compute         keatom mobile ke/atom
variable        atemp atom c_keatom/(1.5*8.617333262e-5)
compute         zchunks all chunk/atom bin/1d z lower ${nemd_bin_size_a} units box

fix             prof mobile ave/chunk 100 1000 100000 zchunks v_atemp file ${outdir}/gc_rebo2_Tprofile.dat

fix             hotcold_avg all ave/time 100 10 1000 c_Thot c_Tcold ave running mode scalar
variable        dT equal f_hotcold_avg[1]-f_hotcold_avg[2]
variable        Jz equal abs(${nemd_eflux_ev_ps})/v_area
variable        kappa equal ternary(abs(v_dT)>1.0e-12, 1602.176634*v_Jz*v_dz/v_dT, 0.0)

fix             stats all ave/time 100000 1 100000 f_hotcold_avg[1] f_hotcold_avg[2] v_dT v_Jz v_kappa file ${outdir}/gc_rebo2_hotcold.dat mode scalar

thermo_modify   temp Tmobile
thermo_style    custom step c_Tmobile c_Thot c_Tcold v_dT v_Jz v_kappa pe ke etotal press
thermo_modify   flush yes
dump            trj all custom 50000 ${outdir}/gc_rebo2_nemd.lammpstrj id type x y z vx vy vz
run             ${nemd_steps}

write_restart   ${outdir}/gc_rebo2_nemd.restart
write_data      ${outdir}/gc_rebo2_nemd.data
