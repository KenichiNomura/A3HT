echo            both
units           metal
dimension       3
boundary        p p p
atom_style      atomic

variable        procx index *
variable        procy index *
variable        procz index *
include         simulation_plan.lmp

variable        outdir string data
shell           mkdir ${outdir}

processors      ${procx} ${procy} ${procz}

read_data       random_carbon.dat

mass            1 12.011

pair_style      rebo
pair_coeff      * * CH.rebo C

neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes

compute         coord all coord/atom cutoff ${anneal_coord_cutoff_a}
variable        is2 atom (c_coord>=1.5 && c_coord<2.5)
variable        is3 atom (c_coord>=2.5 && c_coord<3.5)
variable        is4 atom (c_coord>=3.5 && c_coord<4.5)
compute         n2 all reduce sum v_is2
compute         n3 all reduce sum v_is3
compute         n4 all reduce sum v_is4

thermo          1000
thermo_modify   flush yes
timestep        ${anneal_timestep_ps}
thermo_style    custom step temp pe ke etotal press vol lx ly lz c_n2 c_n3 c_n4

reset_timestep  0
min_style       cg
minimize        1.0e-10 1.0e-10 10000 100000

velocity        all create ${anneal_tstart_k} ${anneal_velocity_seed} mom yes rot no dist gaussian
fix             mom all momentum 100 linear 1 1 1

dump            traj all custom 5000 ${outdir}/anneal_gc_rebo2.lammpstrj id type x y z vx vy vz
fix             coordlog all ave/time 100 10 1000 c_n2 c_n3 c_n4 file ${outdir}/anneal_gc_rebo2_coordination.dat mode scalar

fix             anneal1 all nvt temp ${anneal_t1_k} ${anneal_t1_k} ${anneal_tdamp_ps}
run             ${anneal_10ps_steps}
unfix           anneal1

fix             anneal2 all nvt temp ${anneal_t2_k} ${anneal_t2_k} ${anneal_tdamp_ps}
run             ${anneal_10ps_steps}
unfix           anneal2

fix             anneal3 all nvt temp ${anneal_t3_k} ${anneal_t3_k} ${anneal_tdamp_ps}
run             ${anneal_10ps_steps}
unfix           anneal3

fix             anneal4 all nvt temp ${anneal_t4_k} ${anneal_t4_k} ${anneal_tdamp_ps}
run             ${anneal_10ps_steps}
unfix           anneal4

fix             anneal5 all nvt temp ${anneal_t5_k} ${anneal_t5_k} ${anneal_tdamp_ps}
run             ${anneal_50ps_steps}
unfix           anneal5

undump          traj
unfix           coordlog
write_restart   ${outdir}/anneal_gc_rebo2.restart
write_data      ${outdir}/anneal_gc_rebo2.data
